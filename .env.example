# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=edu_management
DB_USER=root
DB_PASS=

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/university
APP_KEY=change_this_to_random_32_char_string

# ── Session ───────────────────────────────────────────────────
SESSION_LIFETIME=7200
SESSION_SECURE=false

# ── Mail (cho notification email) ────────────────────────────
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@tdmu.edu.vn
MAIL_FROM_NAME=TDMU

# ── JWT (cho API layer) ───────────────────────────────────────
JWT_SECRET=change_this_to_random_64_char_string
JWT_EXPIRE=3600

# ── Firebase (cho push notification) ─────────────────────────
FIREBASE_SERVER_KEY=
